// ─────────────────────────────────────────────────────────────────────────────
// prisma/schema.prisma
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  ORGANIZER
  USER
}

// ─── AUTH & USERS ─────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  events        Event[]        @relation("UserEvents")
  categories    Category[]     @relation("UserCategories")
  marketProfile MarketProfile?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── CATEGORIES ───────────────────────────────────────────────────────────────

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  icon      String?
  iconColor String?
  createdAt DateTime @default(now())

  createdById String?
  createdBy   User?   @relation("UserCategories", fields: [createdById], references: [id], onDelete: SetNull)

  events EventCategory[]
}

// ─── EVENTS ───────────────────────────────────────────────────────────────────

model Event {
  id          Int      @id @default(autoincrement())
  image       String
  title       String
  date        DateTime
  time        String
  location    String
  description String
  mapUrl      String?
  host        String
  attendees   Int      @default(0)
  createdAt   DateTime @default(now())

  createdById String
  createdBy   User   @relation("UserEvents", fields: [createdById], references: [id], onDelete: Cascade)

  categories         EventCategory[]
  tickets            Ticket[]
  promoCodes         PromoCode[]
  orders             Order[]
  vendorApplications VendorApplication[]
}

model EventCategory {
  eventId    Int
  categoryId Int

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([eventId, categoryId])
}

// ─── TICKETS & ORDERS ─────────────────────────────────────────────────────────

model Ticket {
  id       Int       @id @default(autoincrement())
  type     String
  price    String
  link     String
  isActive Boolean   @default(true)
  startsAt DateTime?
  endsAt   DateTime?

  eventId Int
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model PromoCode {
  id        String   @id @default(cuid())
  code      String
  discount  String
  maxUses   Int      @default(50)
  uses      Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  eventId Int
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, code])
}

model Order {
  id          String   @id @default(cuid())
  email       String
  phone       String
  name        String
  promoCode   String?
  discount    String?
  totalAmount Float    @default(0)
  isRsvp      Boolean  @default(false)
  status      String   @default("confirmed")
  createdAt   DateTime @default(now())

  eventId Int
  event   Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items   OrderItem[]
}

model OrderItem {
  id         String @id @default(cuid())
  ticketId   Int
  ticketType String
  price      String
  quantity   Int    @default(1)
  ticketCode String @unique

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ─── MARKETPLACE ──────────────────────────────────────────────────────────────

model MarketProfile {
  id           String   @id @default(cuid())
  businessName String
  tagline      String?
  description  String
  category     String
  subCategory  String?
  location     String
  phone        String
  email        String
  website      String?
  instagram    String?
  twitter      String?
  facebook     String?
  tiktok       String?
  coverImage   String?
  logoImage    String?
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(true)
  rating       Float    @default(0)
  reviewCount  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  listings     MarketListing[]
  applications VendorApplication[]
  reviews      MarketReview[]
  inquiries    MarketInquiry[]

  @@index([category])
  @@index([isActive])
}

model MarketListing {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  priceType   String
  price       Float?
  currency    String   @default("KES")
  images      String[]
  tags        String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profileId String
  profile   MarketProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  inquiries MarketInquiry[]

  @@index([profileId])
  @@index([category])
}

model VendorApplication {
  id              String   @id @default(cuid())
  message         String
  servicesOffered String
  proposedPrice   Float?
  currency        String   @default("KES")
  status          String   @default("pending")
  ownerNote       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profileId String
  profile   MarketProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  eventId Int
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([profileId, eventId])
  @@index([eventId])
  @@index([status])
}

model MarketInquiry {
  id          String   @id @default(cuid())
  senderName  String
  senderEmail String
  senderPhone String?
  message     String
  status      String   @default("unread")
  reply       String?
  createdAt   DateTime @default(now())

  profileId String
  profile   MarketProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  listingId String?
  listing   MarketListing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([profileId])
  @@index([status])
}

model MarketReview {
  id            String   @id @default(cuid())
  reviewerName  String
  reviewerEmail String
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())

  profileId String
  profile   MarketProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}