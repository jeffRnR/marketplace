// GENERATOR & DATASOURCE
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ENUMS
enum Role {
  ADMIN
  ORGANIZER
  USER
}

// MODELS
model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique // CHANGED: removed ? to make it required
  password  String? // Hashed password for credentials login
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts   Account[]
  sessions   Session[]
  events     Event[]    @relation("UserEvents")
  categories Category[] @relation("UserCategories")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  icon        String?
  iconColor   String?
  createdAt   DateTime @default(now())

  createdById String?
  createdBy   User?    @relation("UserCategories", fields: [createdById], references: [id], onDelete: SetNull)

  // Many-to-many via explicit join table
  events      EventCategory[]
}

model Event {
  id          Int      @id @default(autoincrement())
  image       String
  title       String
  date        DateTime
  time        String
  location    String
  description String
  mapUrl      String?
  host        String
  attendees   Int      @default(0)
  createdAt   DateTime @default(now())

  createdById String
  createdBy   User     @relation("UserEvents", fields: [createdById], references: [id], onDelete: Cascade)

  // Many-to-many via explicit join table
  categories  EventCategory[]
  tickets     Ticket[]
  promoCodes PromoCode[]
  orders Order[]
}

model EventCategory {
  eventId    Int
  categoryId Int

  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([eventId, categoryId])
}

model Ticket {
  id    Int    @id @default(autoincrement())
  type  String
  price String
  link  String

  eventId Int
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  isActive  Boolean   @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
}

// NEXTAUTH MODELS
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PromoCode {
  id        String   @id @default(cuid())
  eventId   Int
  code      String
  discount  String
  maxUses   Int      @default(50)
  uses      Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, code])
}

model Order {
  id          String   @id @default(cuid())
  eventId     Int
  email       String
  phone       String
  name        String
  promoCode   String?
  discount    String?
  totalAmount Float    @default(0)
  isRsvp      Boolean  @default(false)
  status      String   @default("confirmed")
  createdAt   DateTime @default(now())

  event Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items OrderItem[]
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  ticketId   Int
  ticketType String
  price      String
  quantity   Int    @default(1)
  ticketCode String @unique

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
