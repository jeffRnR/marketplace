// ─────────────────────────────────────────────────────────────────────────────
// prisma/schema.prisma
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  ORGANIZER
  USER
}

// ─── AUTH & USERS ─────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts         Account[]
  sessions         Session[]
  events           Event[]           @relation("UserEvents")
  categories       Category[]        @relation("UserCategories")
  marketProfile    MarketProfile?
  wallet           VendorWallet?
  slotApplications SlotApplication[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── CATEGORIES ───────────────────────────────────────────────────────────────

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  icon      String?
  iconColor String?
  createdAt DateTime @default(now())

  createdById String?
  createdBy   User?   @relation("UserCategories", fields: [createdById], references: [id], onDelete: SetNull)

  events EventCategory[]
}

// ─── EVENTS ───────────────────────────────────────────────────────────────────

model Event {
  id          Int      @id @default(autoincrement())
  image       String
  title       String
  date        DateTime
  time        String
  location    String
  description String
  mapUrl      String?
  host        String
  attendees   Int      @default(0)
  createdAt   DateTime @default(now())

  createdById String
  createdBy   User   @relation("UserEvents", fields: [createdById], references: [id], onDelete: Cascade)

  categories         EventCategory[]
  tickets            Ticket[]
  promoCodes         PromoCode[]
  orders             Order[]
  vendorApplications VendorApplication[]
  vendingSlots       VendingSlot[]
}

model EventCategory {
  eventId    Int
  categoryId Int

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([eventId, categoryId])
}

// ─── TICKETS & ORDERS ─────────────────────────────────────────────────────────

model Ticket {
  id       Int       @id @default(autoincrement())
  type     String
  price    String
  link     String
  isActive Boolean   @default(true)
  startsAt DateTime?
  endsAt   DateTime?

  eventId Int
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model PromoCode {
  id        String   @id @default(cuid())
  code      String
  discount  String
  maxUses   Int      @default(50)
  uses      Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  eventId Int
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, code])
}

model Order {
  id          String   @id @default(cuid())
  email       String
  phone       String
  name        String
  promoCode   String?
  discount    String?
  totalAmount Float    @default(0)
  isRsvp      Boolean  @default(false)
  // "pending" | "confirmed" | "failed" | "cancelled"
  status      String   @default("confirmed")
  createdAt   DateTime @default(now())

  eventId Int
  event   Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items   OrderItem[]

  // Link to payment record (null for RSVP / free orders)
  paymentRecord PaymentRecord?

  @@index([eventId])
  @@index([status])
  @@index([email])
}

model OrderItem {
  id         String @id @default(cuid())
  ticketId   Int
  ticketType String
  price      String
  quantity   Int    @default(1)
  ticketCode String @unique

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ─── PAYMENT RECORDS ─────────────────────────────────────────────────────────
// Immutable record of every Flutterwave transaction.
// txRef is our idempotency key — generated before redirect, verified on webhook.
// type: "ticket" | "vending_slot"

model PaymentRecord {
  id        String   @id @default(cuid())
  txRef     String   @unique   // our UUID sent to Flutterwave
  flwRef    String?            // Flutterwave's reference (set on webhook)
  type      String             // "ticket" | "vending_slot"
  amount    Float
  currency  String   @default("KES")
  phone     String
  // "pending" | "successful" | "failed"
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One of these is set depending on type
  orderId         String?          @unique
  order           Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)

  slotApplicationId String?        @unique
  slotApplication   SlotApplication? @relation(fields: [slotApplicationId], references: [id], onDelete: SetNull)

  @@index([txRef])
  @@index([status])
}

// ─── VENDING SLOTS ────────────────────────────────────────────────────────────

model VendingSlot {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  currency    String   @default("KES")
  totalSlots  Int                        // NEVER exposed to public
  // "open" | "closed"
  status      String   @default("open")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eventId Int
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  applications SlotApplication[]

  @@index([eventId])
  @@index([status])
}

// ─── SLOT APPLICATIONS ────────────────────────────────────────────────────────
// status flow: "pending" → "approved" → "paid" → "confirmed"
//                       → "rejected"
//              "approved" → "expired" (if not paid within 48h)

model SlotApplication {
  id              String   @id @default(cuid())
  businessName    String             // snapshot at time of application
  contactName     String
  contactEmail    String
  contactPhone    String
  description     String             // what they plan to sell/offer
  hasPriority     Boolean  @default(false)  // true if applicant has a MarketProfile
  // "pending" | "approved" | "rejected" | "paid" | "confirmed" | "expired"
  status          String   @default("pending")
  ownerNote       String?            // event owner's note on approve/reject
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  slotId String
  slot   VendingSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)

  // Applicant user (required — must be logged in to apply)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Optional link to their market profile (sets hasPriority = true)
  marketProfileId String?
  marketProfile   MarketProfile? @relation(fields: [marketProfileId], references: [id], onDelete: SetNull)

  paymentRecord PaymentRecord?

  @@unique([slotId, userId])   // one application per user per slot
  @@index([slotId])
  @@index([userId])
  @@index([status])
}

// ─── VENDOR WALLET ────────────────────────────────────────────────────────────
// One wallet per user. Created lazily when they first receive a payment.

model VendorWallet {
  id             String   @id @default(cuid())
  balance        Float    @default(0)   // available to withdraw
  totalEarned    Float    @default(0)   // lifetime credited (before fees)
  totalWithdrawn Float    @default(0)   // lifetime withdrawn
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions       WalletTransaction[]
  withdrawalRequests WithdrawalRequest[]
}

// ─── WALLET TRANSACTIONS ──────────────────────────────────────────────────────
// Immutable ledger — never updated or deleted after creation.
// type: "credit" | "platform_fee" | "withdrawal" | "refund"

model WalletTransaction {
  id          String   @id @default(cuid())
  type        String
  amount      Float
  description String
  // Snapshot of balance AFTER this transaction (for audit trail)
  balanceAfter Float
  createdAt   DateTime @default(now())

  walletId String
  wallet   VendorWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  // Reference to the source payment (for traceability)
  paymentTxRef String?

  @@index([walletId])
  @@index([createdAt])
}

// ─── WITHDRAWAL REQUESTS ──────────────────────────────────────────────────────
// status: "pending" | "processing" | "completed" | "failed"
// Payout details encrypted at rest with AES-256-GCM (lib/encryption.ts)

model WithdrawalRequest {
  id     String @id @default(cuid())
  amount Float
  // "mpesa" | "bank"
  method String

  // Encrypted JSON blob — decrypt only at payout time
  // For mpesa: { phone: string }
  // For bank:  { accountName: string, accountNumber: string, bankName: string, bankCode: string }
  encryptedPayoutDetails String @db.Text

  // "pending" | "processing" | "completed" | "failed"
  status      String   @default("pending")
  failureNote String?
  // Flutterwave transfer reference (set when processing starts)
  flwTransferRef String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  walletId String
  wallet   VendorWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([status])
}

// ─── MARKETPLACE ──────────────────────────────────────────────────────────────

model MarketProfile {
  id           String   @id @default(cuid())
  businessName String
  tagline      String?
  description  String
  category     String
  subCategory  String?
  location     String
  phone        String
  email        String
  website      String?
  instagram    String?
  twitter      String?
  facebook     String?
  tiktok       String?
  coverImage   String?
  logoImage    String?
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(true)
  rating       Float    @default(0)
  reviewCount  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  listings         MarketListing[]
  applications     VendorApplication[]
  reviews          MarketReview[]
  inquiries        MarketInquiry[]
  slotApplications SlotApplication[]

  @@index([category])
  @@index([isActive])
}

model MarketListing {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  priceType   String
  price       Float?
  currency    String   @default("KES")
  images      String[]
  tags        String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profileId String
  profile   MarketProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  inquiries MarketInquiry[]

  @@index([profileId])
  @@index([category])
}

model VendorApplication {
  id              String   @id @default(cuid())
  message         String
  servicesOffered String
  proposedPrice   Float?
  currency        String   @default("KES")
  status          String   @default("pending")
  ownerNote       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profileId String
  profile   MarketProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  eventId Int
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([profileId, eventId])
  @@index([eventId])
  @@index([status])
}

model MarketInquiry {
  id          String   @id @default(cuid())
  senderName  String
  senderEmail String
  senderPhone String?
  message     String
  status      String   @default("unread")
  reply       String?
  createdAt   DateTime @default(now())

  profileId String
  profile   MarketProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  listingId String?
  listing   MarketListing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([profileId])
  @@index([status])
}

model MarketReview {
  id            String   @id @default(cuid())
  reviewerName  String
  reviewerEmail String
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())

  profileId String
  profile   MarketProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}


