generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  ORGANIZER
  USER
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts         Account[]
  sessions         Session[]
  events           Event[]           @relation("UserEvents")
  categories       Category[]        @relation("UserCategories")
  marketProfile    MarketProfile?
  wallet           VendorWallet?
  slotApplications SlotApplication[]
  conversationsAsBuyer Conversation[] @relation("ConversationBuyer")
  sentMessages         Message[]
  notifications        Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  icon        String?
  iconColor   String?
  createdAt   DateTime @default(now())
  createdById String?
  createdBy   User?    @relation("UserCategories", fields: [createdById], references: [id], onDelete: SetNull)
  events EventCategory[]
}

model Event {
  id          Int      @id @default(autoincrement())
  image       String
  title       String
  date        DateTime
  time        String
  location    String
  description String
  mapUrl      String?
  host        String
  attendees   Int      @default(0)
  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation("UserEvents", fields: [createdById], references: [id], onDelete: Cascade)
  categories         EventCategory[]
  tickets            Ticket[]
  promoCodes         PromoCode[]
  orders             Order[]
  vendorApplications VendorApplication[]
  vendingSlots       VendingSlot[]
}

model EventCategory {
  eventId    Int
  categoryId Int
  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  @@id([eventId, categoryId])
}

model Ticket {
  id       Int       @id @default(autoincrement())
  type     String
  price    String
  link     String
  isActive Boolean   @default(true)
  startsAt DateTime?
  endsAt   DateTime?
  eventId  Int
  event    Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model PromoCode {
  id        String   @id @default(cuid())
  code      String
  discount  String
  maxUses   Int      @default(50)
  uses      Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  eventId   Int
  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  @@unique([eventId, code])
}

model Order {
  id          String   @id @default(cuid())
  email       String
  phone       String
  name        String
  promoCode   String?
  discount    String?
  totalAmount Float    @default(0)
  isRsvp      Boolean  @default(false)
  status      String   @default("confirmed")
  createdAt   DateTime @default(now())
  eventId     Int
  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items       OrderItem[]
  paymentRecord PaymentRecord?
  @@index([eventId])
  @@index([status])
  @@index([email])
}

model OrderItem {
  id         String @id @default(cuid())
  ticketId   Int
  ticketType String
  price      String
  quantity   Int    @default(1)
  ticketCode String @unique
  orderId    String
  order      Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model PaymentRecord {
  id        String   @id @default(cuid())
  txRef     String   @unique
  flwRef    String?
  type      String
  amount    Float
  currency  String   @default("KES")
  phone     String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orderId           String?          @unique
  order             Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  slotApplicationId String?          @unique
  slotApplication   SlotApplication? @relation(fields: [slotApplicationId], references: [id], onDelete: SetNull)
  serviceBookingId  String?          @unique
  serviceBooking    ServiceBooking?  @relation(fields: [serviceBookingId], references: [id], onDelete: SetNull)
  @@index([txRef])
  @@index([status])
}

model VendingSlot {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  currency    String   @default("KES")
  totalSlots  Int
  status      String   @default("open")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  eventId      Int
  event        Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  applications SlotApplication[]
  @@index([eventId])
  @@index([status])
}

model SlotApplication {
  id              String   @id @default(cuid())
  businessName    String
  contactName     String
  contactEmail    String
  contactPhone    String
  description     String
  hasPriority     Boolean  @default(false)
  status          String   @default("pending")
  ownerNote       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  slotId          String
  slot            VendingSlot    @relation(fields: [slotId], references: [id], onDelete: Cascade)
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketProfileId String?
  marketProfile   MarketProfile? @relation(fields: [marketProfileId], references: [id], onDelete: SetNull)
  paymentRecord   PaymentRecord?
  @@unique([slotId, userId])
  @@index([slotId])
  @@index([userId])
  @@index([status])
}

model VendorWallet {
  id             String   @id @default(cuid())
  balance        Float    @default(0)
  totalEarned    Float    @default(0)
  totalWithdrawn Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions       WalletTransaction[]
  withdrawalRequests WithdrawalRequest[]
}

model WalletTransaction {
  id           String   @id @default(cuid())
  type         String
  amount       Float
  description  String
  balanceAfter Float
  createdAt    DateTime @default(now())
  walletId     String
  wallet       VendorWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  paymentTxRef String?
  @@index([walletId])
  @@index([createdAt])
}

model WithdrawalRequest {
  id                     String   @id @default(cuid())
  amount                 Float
  method                 String
  encryptedPayoutDetails String   @db.Text
  status                 String   @default("pending")
  failureNote            String?
  flwTransferRef         String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  walletId String
  wallet   VendorWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  @@index([walletId])
  @@index([status])
}

model MarketProfile {
  id           String   @id @default(cuid())
  businessName String
  tagline      String?
  description  String
  category     String
  subCategory  String?
  location     String
  phone        String
  email        String
  website      String?
  instagram    String?
  twitter      String?
  facebook     String?
  tiktok       String?
  coverImage   String?
  logoImage    String?
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(true)
  rating       Float    @default(0)
  reviewCount  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings         MarketListing[]
  applications     VendorApplication[]
  reviews          MarketReview[]
  inquiries        MarketInquiry[]
  slotApplications SlotApplication[]
  conversations    Conversation[]
  @@index([category])
  @@index([isActive])
}

model MarketListing {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  priceType   String
  price       Float?
  currency    String   @default("KES")
  images      String[]
  tags        String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  profileId String
  profile   MarketProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  inquiries     MarketInquiry[]
  conversations Conversation[]
  bookings      ServiceBooking[]
  @@index([profileId])
  @@index([category])
}

model VendorApplication {
  id              String   @id @default(cuid())
  message         String
  servicesOffered String
  proposedPrice   Float?
  currency        String   @default("KES")
  status          String   @default("pending")
  ownerNote       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  profileId String
  profile   MarketProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  eventId   Int
  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  @@unique([profileId, eventId])
  @@index([eventId])
  @@index([status])
}

model MarketInquiry {
  id          String   @id @default(cuid())
  senderName  String
  senderEmail String
  senderPhone String?
  message     String
  status      String   @default("unread")
  reply       String?
  createdAt   DateTime @default(now())
  profileId String
  profile   MarketProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  listingId String?
  listing   MarketListing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  @@index([profileId])
  @@index([status])
}

model MarketReview {
  id            String   @id @default(cuid())
  reviewerName  String
  reviewerEmail String
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())
  profileId String
  profile   MarketProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  @@index([profileId])
}

model Conversation {
  id            String   @id @default(cuid())
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  buyerId         String
  buyer           User          @relation("ConversationBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  vendorProfileId String
  vendorProfile   MarketProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  listingId String?
  listing   MarketListing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  messages Message[]
  bookings ServiceBooking[]
  @@unique([buyerId, vendorProfileId, listingId])
  @@index([buyerId])
  @@index([vendorProfileId])
  @@index([lastMessageAt])
}

model Message {
  id             String    @id @default(cuid())
  content        String    @db.Text
  readAt         DateTime?
  createdAt      DateTime  @default(now())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId String
  sender   User   @relation(fields: [senderId], references: [id], onDelete: Cascade)
  @@index([conversationId])
  @@index([senderId])
  @@index([readAt])
}

model ServiceBooking {
  id            String    @id @default(cuid())
  eventDate     DateTime?
  quantity      Int       @default(1)
  notes         String?
  totalAmount   Float
  currency      String    @default("KES")
  paymentMethod String    @default("mpesa")
  status        String    @default("pending")
  vendorNote    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  conversationId String
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  listingId String
  listing   MarketListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  paymentRecord PaymentRecord?
  @@index([conversationId])
  @@index([listingId])
  @@index([status])
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────
// Universal in-app notifications.
// type: "ticket_order" | "rsvp" | "vending_application" | "vending_confirmed"
//       "booking_request" | "booking_approved" | "booking_rejected"
//       "booking_confirmed" | "new_message"

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String
  linkUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}
